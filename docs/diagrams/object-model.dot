//
// Object Model (Graphviz DOT)
// Render: dot -Tsvg object-model.dot -o object-model.svg

digraph ObjectModel {
    rankdir=TB;
    node [shape=record, fontname="Helvetica", fontsize=9, style=filled, fillcolor="#f5f5f5"];
    edge [fontname="Helvetica", fontsize=8];

    // Server layer
    Server [fillcolor="#bbdefb", label="{Server (internal/server)|router: *gin.Engine\laudiobookService: AudiobookService\loperationQueue: *OperationQueue\l|listAudiobooks()\lgetAudiobook()\lupdateAudiobook()\lstartScan()\lstartOrganize()\lhandleITunesImport()\l...189 handlers\l}"];

    AudiobookService [fillcolor="#bbdefb", label="{AudiobookService|store: Store\l|GetAudiobook()\lListAudiobooks()\lCountAudiobooks()\lEnrichBook()\l}"];

    // Store layer
    Store [fillcolor="#c8e6c9", label="{«interface» Store|255 methods\l|GetAllBooks()\lGetBookByID()\lGetBookByFilePath()\lGetBookByFileHash()\lCreateBook()\lUpdateBook()\lDeleteBook()\lGetAllAuthors()\lCreateAuthor()\l...\l}"];

    PebbleStore [fillcolor="#a5d6a7", label="{PebbleStore|db: *pebble.DB\l|implements Store\l}"];

    AIScanStore [fillcolor="#a5d6a7", label="{AIScanStore|db: *pebble.DB (ai_scans.db)\l|CreateScan()\lGetScan()\lSavePhase()\lSaveResult()\lGetResults()\l}"];

    // Core packages
    Scanner [fillcolor="#fff9c4", label="{Scanner (internal/scanner)|ScanDirectory()\lComputeFileHash()\lExtractMetadata()\l}"];

    Organizer [fillcolor="#fff9c4", label="{Organizer (internal/organizer)|Organize()\lBuildTargetPath()\lWriteMetadataTags()\l}"];

    MetadataFetcher [fillcolor="#fff9c4", label="{Metadata (internal/metadata)|SearchMetadata()\lApplyCandidate()\lExtractCoverArt()\lExtractMediaInfo()\l}"];

    OpenAIParser [fillcolor="#fff9c4", label="{OpenAIParser (internal/ai)|ParseFilename()\lParseAudiobook()\lReviewAuthorDuplicates()\lCreateBatchAuthorDedup()\l}"];

    OperationQueue [fillcolor="#fff9c4", label="{OperationQueue (internal/operations)|timeout: Duration\l|Enqueue()\lSetOperationTimeout()\lSaveCheckpoint()\lLoadCheckpoint()\l}"];

    Config [fillcolor="#ffe0b2", label="{Config (internal/config)|RootDir\lDatabasePath\lFolderNamingPattern\lFileNamingPattern\lConcurrentScans\lOperationTimeoutMinutes\lMetadataSources\l...100+ fields\l}"];

    // Entity types
    Book [fillcolor="#e1bee7", label="{Book|ID: ULID\lTitle: string\lAuthorID: *int\lSeriesID: *int\lFilePath: string\lFormat: string\lDuration: *int\lVersionGroupID: *string\lIsPrimaryVersion: *bool\lFileHash: *string\lLibraryState: *string\l...50+ fields\l}"];

    Author [fillcolor="#e1bee7", label="{Author|ID: int\lName: string\l}"];
    Series [fillcolor="#e1bee7", label="{Series|ID: int\lName: string\lAuthorID: *int\l}"];
    Narrator [fillcolor="#e1bee7", label="{Narrator|ID: int\lName: string\l}"];
    Work [fillcolor="#e1bee7", label="{Work|ID: ULID\lTitle: string\l}"];
    BookSegment [fillcolor="#e1bee7", label="{BookSegment|ID: ULID\lBookID: int (numeric)\lFilePath: string\l}"];
    BookAuthor [fillcolor="#e1bee7", label="{BookAuthor|BookID: ULID\lAuthorID: int\lRole: string\l}"];
    Operation [fillcolor="#e1bee7", label="{Operation|ID: ULID\lType: string\lStatus: string\lProgress: int\l}"];

    // Edges
    Server -> AudiobookService;
    Server -> OperationQueue;
    Server -> Config [style=dashed];
    AudiobookService -> Store;
    Store -> PebbleStore [style=dashed, label="implements"];
    PebbleStore -> Book [label="stores"];
    PebbleStore -> Author [label="stores"];
    PebbleStore -> Series [label="stores"];
    Scanner -> Store;
    Scanner -> MetadataFetcher;
    Organizer -> Store;
    OpenAIParser -> AIScanStore;
    OperationQueue -> Operation [label="manages"];
    Book -> Author [label="AuthorID"];
    Book -> Series [label="SeriesID"];
    Book -> Work [label="WorkID", style=dashed];
    Book -> BookSegment [label="1:N"];
    Book -> BookAuthor [label="1:N"];
    BookAuthor -> Author [label="AuthorID"];
}
