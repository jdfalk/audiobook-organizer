    %% Relationships
    Server --> AudiobookService
    Server --> OperationQueue
    AudiobookService --> Store
    Store <|.. PebbleStore : implements
    PebbleStore --> Book : stores
    PebbleStore --> Author : stores
    PebbleStore --> Series : stores
    Book --> Author : AuthorID
    Book --> Series : SeriesID
    Book --> Work : WorkID
    Book "1" --> "*" BookSegment : has
    Book "1" --> "*" BookAuthor : has
    Book "1" --> "*" BookNarrator : has
    BookAuthor --> Author : AuthorID
    BookNarrator --> Narrator : NarratorID
    Series --> Author : AuthorID (optional)
    Scanner --> Store : reads/writes
    Scanner --> MetadataFetcher : extracts
    Organizer --> Store : reads/writes
    OpenAIParser --> AIScanStore : stores results
    OperationQueue --> Operation : manages
    Server --> Config : reads
