        +string ID (ULID)
        +string Title
        +*int AuthorID
        +*int SeriesID
        +string FilePath
        +string Format
        +*int Duration
        +*string VersionGroupID
        +*bool IsPrimaryVersion
        +*string FileHash
        +*string LibraryState
        +*string ITunesPersistentID
        +*bool MarkedForDeletion
        ...50+ fields
    }

    class Author {
        +int ID
        +string Name
    }

    class Series {
        +int ID
        +string Name
        +*int AuthorID
    }

    class Narrator {
        +int ID
        +string Name
    }

    class Work {
        +string ID (ULID)
        +string Title
        +*int AuthorID
        +*int SeriesID
    }

    class BookSegment {
        +string ID (ULID)
        +int BookID (numeric)
        +string FilePath
        +string Format
        +int64 SizeBytes
        +int DurationSec
        +*int TrackNumber
        +*string FileHash
        +bool Active
    }

    class BookAuthor {
        +string BookID (ULID)
        +int AuthorID
        +string Role
        +int Position
    }

    class BookNarrator {
        +string BookID (ULID)
        +int NarratorID
        +string Role
        +int Position
    }

    class Operation {
        +string ID (ULID)
        +string Type
        +string Status
        +int Progress
        +int Total
        +string Message
    }

    class OperationQueue {
        +timeout time.Duration
        +Enqueue(id, type, path, fn)
        +SetOperationTimeout(d)
        +SaveCheckpoint(store, opID, ...)
        +LoadCheckpoint(store, opID)
    }

    class Scanner {
        +ScanDirectory(path, store, opts) error
        +ComputeFileHash(path) (string, error)
        +ExtractMetadata(path) (*Book, error)
    }

    class Organizer {
        +Organize(book, pattern, store) error
        +BuildTargetPath(book, pattern) string
        +WriteMetadataTags(book, path) error
    }

    class MetadataFetcher {
        +SearchMetadata(title, author) ([]Candidate, error)
        +ApplyCandidate(book, candidate, fields) error
        +ExtractCoverArt(path) (string, error)
    }

    class OpenAIParser {
